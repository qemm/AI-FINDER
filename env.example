# GitHub/GitLab tokens for API search (optional — increases rate limit)
GITHUB_TOKEN=
GITLAB_TOKEN=

# Comma-separated allowed origins for the backend CORS policy
CORS_ORIGINS=http://localhost:5173

# ---------------------------------------------------------------------------
# Web search — API engines avoid CAPTCHAs and IP blocks entirely.
# Use these instead of (or alongside) direct scraping.
# ---------------------------------------------------------------------------

# Google Custom Search JSON API — 100 free queries/day.
# 1. Create a project: https://console.developers.google.com
# 2. Enable "Custom Search API"
# 3. Create an API key and a Search Engine at https://cse.google.com
#    (tick "Search the entire web" in the configuration)
GOOGLE_CSE_KEY=
GOOGLE_CSE_ID=

# Brave Search API — 2 000 free queries/month.
# Sign up at https://api.search.brave.com
BRAVE_SEARCH_KEY=

# HTTP or SOCKS5 proxy for scraping-based engines (helps bypass IP blocks).
# Example: HTTPS_PROXY=socks5://user:pass@proxy-host:1080
HTTPS_PROXY=
